    "slides": [
        {
            "id": "s8_5_1",
            "type": "text",
            "title": "break Statement",
            "content": "`break` exits a loop immediately, regardless of the loop condition. It's often used inside an `if` to stop early.\n\n```r\nfor (i in 1:10) {\n  if (i > 5) break\n  print(i)\n}\n```"
        },
        {
            "id": "s8_5_2",
            "type": "code",
            "title": "break Example",
            "content": "Run:",
            "codeSnippet": "for (i in 1:10) {\n  if (i == 6) break\n  print(i)\n}",
            "codeLanguage": "r",
            "canRunCode": true
        },
        {
            "id": "s8_5_3",
            "type": "quiz",
            "title": "break Quiz 🧠",
            "content": "",
            "quizData": {
                "id": "q8_5_1",
                "type": "multiple_choice",
                "question": "What does `break` do in a loop?",
                "options": [
                    {
                        "id": "opt1",
                        "text": "Skips the current iteration",
                        "isCorrect": false
                    },
                    {
                        "id": "opt2",
                        "text": "Exits the loop entirely",
                        "isCorrect": true
                    },
                    {
                        "id": "opt3",
                        "text": "Pauses the loop",
                        "isCorrect": false
                    },
                    {
                        "id": "opt4",
                        "text": "Restarts the loop",
                        "isCorrect": false
                    }
                ],
                "explanation": "break terminates the loop.",
                "xpReward": 10
            }
        },
        {
            "id": "s8_5_4",
            "type": "text",
            "title": "next Statement",
            "content": "`next` skips the rest of the current iteration and moves to the next one.\n\n```r\nfor (i in 1:5) {\n  if (i == 3) next\n  print(i)\n}\n```"
        },
        {
            "id": "s8_5_5",
            "type": "code",
            "title": "next Example",
            "content": "Run:",
            "codeSnippet": "for (i in 1:10) {\n  if (i %% 2 == 0) next\n  print(i)  # prints odd numbers\n}",
            "codeLanguage": "r",
            "canRunCode": true
        },
        {
            "id": "s8_5_6",
