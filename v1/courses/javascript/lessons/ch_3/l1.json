        {
            "id": "s_l1_4",
            "type": "code",
            "title": "Equality 🟰",
            "content": "To check if two things are equal, use **triple equals** `===`.\n\nDon't use single `=`, that's for assignment!",
            "codeSnippet": "let age = 18;\nconsole.log(age === 18); // true\nconsole.log(age === 20); // false",
            "codeLanguage": "javascript",
            "canRunCode": true
        },
