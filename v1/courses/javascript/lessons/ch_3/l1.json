            "title": "Greater or Less? 📈",
            "content": "Use `>` for 'greater than' and `<` for 'less than'.",
            "codeSnippet": "console.log(10 > 5); // true\nconsole.log(2 < 1); // false",
            "codeLanguage": "javascript",
            "canRunCode": true
