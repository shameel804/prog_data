            "id": "s_l4_3",
            "type": "code",
            "title": "Before & After 🔄",
            "content": "Compare the two styles:",
            "codeSnippet": "// Standard\nfunction sum(a, b) {\n return a + b;\n}\n\n// Arrow\nconst sum = (a, b) => {\n return a + b;\n};",
