            "type": "text",
            "title": "Connect the Dots ⚫",
            "content": "To get a value out of an object, use the `.` followed by the property name."
        },
        {
            "id": "s_l2_2",
            "type": "code",
            "title": "Example 🚙",
            "content": "Let's get the car's color.",
            "codeSnippet": "let car = {\n  type: 'Fiat',\n  color: 'white'\n};\n\nconsole.log(car.color); // 'white'",
            "codeLanguage": "javascript",
            "canRunCode": true
        },
