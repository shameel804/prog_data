        {
            "id": "s_l1_4",
            "type": "code",
            "title": "Object Destructuring 🏷️",
            "content": "Use curly braces `{ }` matching the property names.",
            "codeSnippet": "let user = { name: 'Alex', age: 24 };\n\n// Variables must match keys!\nlet { name, age } = user;\n\nconsole.log(name); // 'Alex'",
