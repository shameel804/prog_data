            "title": "Unpacking 📦",
            "content": "**Destructuring** is a fancy word for unpacking values from Arrays or properties from Objects into distinct variables."
        },
        {
            "id": "s_l1_2",
            "type": "code",
            "title": "Array Destructuring 🍫",
            "content": "Skip the indexes!",
            "codeSnippet": "// OLD way\nlet rgb = [255, 200, 0];\nlet red = rgb[0];\nlet green = rgb[1];\n\n// NEW way\nlet [r, g, b] = rgb;\nconsole.log(r); // 255",
            "codeLanguage": "javascript",
            "canRunCode": true
        },
