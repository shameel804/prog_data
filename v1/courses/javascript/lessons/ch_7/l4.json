    "slides": [
        {
            "id": "s_l4_1",
            "type": "text",
            "title": "Power Combo ⚡",
            "content": "Arrays and Loops are best friends.\n\nYou often need to do something to **every item** in a list."
        },
        {
            "id": "s_l4_2",
            "type": "code",
            "title": "The Old Way 👴",
            "content": "Using a standard `for` loop.",
            "codeSnippet": "let fruits = ['Apple', 'Banana'];\n\nfor (let i = 0; i < fruits.length; i++) {\n  console.log(fruits[i]);\n}",
            "codeLanguage": "javascript",
            "canRunCode": true
        },
        {
            "id": "s_l4_3",
            "type": "code",
            "title": "The Modern Way ✨",
            "content": "Use `for...of` for a cleaner syntax.",
            "codeSnippet": "let fruits = ['Apple', 'Banana'];\n\nfor (let fruit of fruits) {\n  console.log(fruit);\n}",
            "codeLanguage": "javascript",
            "canRunCode": true
        },
        {
            "id": "s_l4_4",
            "type": "quiz",
            "title": "Quick Check 🧠",
            "content": "",
