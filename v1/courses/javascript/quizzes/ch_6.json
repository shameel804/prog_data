        {
            "id": "q10",
            "type": "mcq",
            "question": "Why should you avoid arrow functions for methods using `this`?",
            "options": [
                "They are too slow",
                "They don't have their own `this`",
                "They are ugly",
                "They are deprecated"
            ],
            "correctAnswer": 1,
