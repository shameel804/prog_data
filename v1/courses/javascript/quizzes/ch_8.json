            "correctAnswer": 1,
            "explanation": "It's the model of the document."
        },
        {
            "id": "q2",
            "type": "mcq",
            "question": "Which object represents the entire HTML page?",
            "options": [
                "window",
                "browser",
                "document",
                "html"
            ],
            "correctAnswer": 2,
            "explanation": "`document` is the root."
        },
        {
            "id": "q3",
            "type": "fill_blank",
            "question": "To find an element with id='main', use querySelector('__')",
            "options": [
                "#main",
                ".main",
                "main",
                "*main"
            ],
            "correctAnswer": "#main",
            "explanation": "Hashtag `#` denotes ID."
        },
        {
            "id": "q4",
            "type": "mcq",
            "question": "Which method selects the FIRST matching element?",
            "options": [
                "selectAll",
                "find",
                "querySelector",
                "getElement"
            ],
            "correctAnswer": 2,
            "explanation": "`querySelector` returns one element."
        },
        {
            "id": "q5",
            "type": "mcq",
            "question": "To change the text inside an element, use:",
            "options": [
                ".text",
                ".value",
                ".innerText",
                ".content"
            ],
            "correctAnswer": 2,
            "explanation": "`innerText` (or `textContent`) modifies the text."
        },
        {
            "id": "q6",
            "type": "true_false",
            "question": "True or False: `innerText` can render HTML tags like `<b>`.",
            "correctAnswer": false,
            "explanation": "No, it treats them as plain text. use `innerHTML` for tags."
        },
        {
            "id": "q7",
            "type": "mcq",
            "question": "How do you change the background color in JS?",
            "options": [
                "style.background-color",
                "style.backgroundColor",
                "css.background",
                "color.bg"
            ],
            "correctAnswer": 1,
            "explanation": "Use camelCase property names in JS."
        },
        {
            "id": "q8",
            "type": "mcq",
            "question": "Which method listens for clicks?",
            "options": [
                "onClick",
                "listen",
                "hear",
                "addEventListener"
            ],
            "correctAnswer": 3,
            "explanation": "`addEventListener` is the standard way."
        },
        {
            "id": "q9",
            "type": "fill_blank",
            "question": "The second argument to `addEventListener` is a __ function",
            "options": [
                "callback",
                "listening",
                "waiting",
                "return"
            ],
            "correctAnswer": "callback",
            "explanation": "It's a function that is 'called back' later."
        },
        {
            "id": "q10",
            "type": "mcq",
            "question": "What is `querySelector('.btn')` looking for?",
            "options": [
                "An ID named btn",
                "A class named btn",
                "A tag named btn",
                "Nothing"
            ],
            "correctAnswer": 1,
            "explanation": "Dot `.` denotes class."
        }
